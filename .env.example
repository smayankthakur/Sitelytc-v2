# ── Sitelytc env vars ── copy to .env.local and fill in. NEVER commit real values.

# HubSpot CRM
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=
# Optional: real pipeline/stage IDs for Agency Leads deals
HUBSPOT_AGENCY_PIPELINE_ID=
HUBSPOT_AGENCY_STAGE_ID=

# Payments — Razorpay (INR)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Payments — Stripe (international)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Form notifications → sitelytc@gmail.com + WhatsApp +91 88268 49403 ──
# EMAIL (pick one). Easiest: Web3Forms (free, no domain needed) — create a key
# at web3forms.com using sitelytc@gmail.com, paste it here:
WEB3FORMS_ACCESS_KEY=
# OR Resend (needs a verified sending domain):
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
# WHATSAPP (pick one). Easiest: CallMeBot (free) — follow callmebot.com/whatsapp
# from +91 88268 49403 to get an apikey, paste it here:
CALLMEBOT_APIKEY=

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Number that receives new-lead WhatsApp notifications
MAYANK_WHATSAPP_NUMBER=918826849403

# Cloudflare Turnstile CAPTCHA
CLOUDFLARE_TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Rate limiting — Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Infra
DATABASE_URL=
NEXTAUTH_SECRET=
# Portal auth — REQUIRED in production (sign the session cookie). Generate with:
#   node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
SESSION_SECRET=
# Demo portal logins (dev): client@demo.sitelytc.com / agency@demo.sitelytc.com — password demo12345

# Booking (client-visible — used in nav/hero CTAs)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/sitelytc/sitelytc-meet

# Analytics — Google Analytics 4 (loads ONLY after cookie consent). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Opt-in inertia smooth scroll (Lenis via CDN). Set to true to enable; respects reduced-motion.
NEXT_PUBLIC_SMOOTH_SCROLL=false

# Public site config
NEXT_PUBLIC_SITE_URL=https://sitelytc.com
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
